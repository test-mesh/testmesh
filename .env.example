# TestMesh Environment Configuration Example
# Copy this file to .env and customize for your environment
# DO NOT commit .env to version control

# =============================================================================
# Port Configuration (Optional - to avoid conflicts)
# =============================================================================

# TestMesh API port (default: 5016)
API_PORT=5016

# Dashboard port (default: 3000)
DASHBOARD_PORT=3000

# Infrastructure ports (for docker-compose.infra.yml)
POSTGRES_PORT=5432
REDIS_PORT=6379
KAFKA_PORT=9092

# Demo microservice ports (for docker-compose.services.yml)
USER_SERVICE_PORT=5001
PRODUCT_SERVICE_PORT=5002
ORDER_SERVICE_PORT=5003
NOTIFICATION_SERVICE_PORT=5004

# =============================================================================
# Application Configuration
# =============================================================================

# Environment: development, staging, production
ENV=production

# Server port (internal - usually leave as 5016)
PORT=5016

# Log level: debug, info, warn, error
LOG_LEVEL=info

# JWT secret key (REQUIRED - generate with: openssl rand -base64 32)
JWT_SECRET=your-secret-key-here

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# =============================================================================
# PostgreSQL Configuration
# =============================================================================

# Option 1: Individual parameters (recommended)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=testmesh
DATABASE_PASSWORD=your-database-password
DATABASE_DBNAME=testmesh
DATABASE_SSLMODE=disable

# Connection pool settings
DATABASE_MAX_CONNS=25
DATABASE_MAX_IDLE=5

# Option 2: Connection URL (alternative to individual parameters)
# DATABASE_URL=postgres://testmesh:password@localhost:5432/testmesh?sslmode=disable

# For SSL/TLS (production):
# DATABASE_SSLMODE=verify-full
# DATABASE_SSLROOTCERT=/path/to/ca-certificate.crt
# DATABASE_SSLCERT=/path/to/client-cert.pem
# DATABASE_SSLKEY=/path/to/client-key.pem

# =============================================================================
# Redis Configuration
# =============================================================================

# Option 1: Individual parameters (recommended)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS_ENABLED=false

# Option 2: Connection URL (alternative)
# REDIS_URL=redis://localhost:6379/0
# With password: redis://:password@localhost:6379/0
# With TLS: rediss://:password@localhost:6380/0

# =============================================================================
# Kafka Configuration (Optional)
# =============================================================================

# Enable Kafka support
KAFKA_ENABLED=false

# Broker addresses (comma-separated)
KAFKA_BROKERS=localhost:9092

# SASL Authentication (optional)
KAFKA_SASL_ENABLED=false
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# TLS Configuration (optional)
KAFKA_TLS_ENABLED=false
KAFKA_TLS_SKIP_VERIFY=false

# =============================================================================
# AI Integration (Optional)
# =============================================================================

# OpenAI API Key (for test generation, MCP integration)
OPENAI_API_KEY=

# Anthropic API Key (for Claude integration)
ANTHROPIC_API_KEY=

# =============================================================================
# AWS Examples (Comment out if not using AWS)
# =============================================================================

# AWS RDS PostgreSQL
# DATABASE_HOST=mydb.abc123.us-east-1.rds.amazonaws.com
# DATABASE_PORT=5432
# DATABASE_USER=testmesh
# DATABASE_PASSWORD=your-rds-password
# DATABASE_DBNAME=testmesh
# DATABASE_SSLMODE=require

# AWS ElastiCache Redis (without auth)
# REDIS_HOST=mycache.abc123.cache.amazonaws.com
# REDIS_PORT=6379
# REDIS_TLS_ENABLED=false

# AWS ElastiCache Redis (with auth token)
# REDIS_HOST=mycache.abc123.cache.amazonaws.com
# REDIS_PORT=6379
# REDIS_PASSWORD=your-auth-token
# REDIS_TLS_ENABLED=true

# AWS MSK Kafka (SASL/SCRAM)
# KAFKA_ENABLED=true
# KAFKA_BROKERS=b-1.mycluster.abc123.kafka.us-east-1.amazonaws.com:9096,b-2.mycluster.abc123.kafka.us-east-1.amazonaws.com:9096
# KAFKA_SASL_ENABLED=true
# KAFKA_SASL_MECHANISM=SCRAM-SHA-512
# KAFKA_SASL_USERNAME=testmesh
# KAFKA_SASL_PASSWORD=your-kafka-password
# KAFKA_TLS_ENABLED=true

# =============================================================================
# GCP Examples (Comment out if not using GCP)
# =============================================================================

# GCP Cloud SQL PostgreSQL (with Cloud SQL Proxy)
# DATABASE_HOST=127.0.0.1
# DATABASE_PORT=5432
# DATABASE_USER=testmesh
# DATABASE_PASSWORD=your-cloudsql-password
# DATABASE_DBNAME=testmesh
# DATABASE_SSLMODE=disable  # Proxy handles SSL

# GCP Cloud SQL PostgreSQL (direct connection with SSL)
# DATABASE_HOST=35.123.45.67
# DATABASE_PORT=5432
# DATABASE_USER=testmesh
# DATABASE_PASSWORD=your-password
# DATABASE_DBNAME=testmesh
# DATABASE_SSLMODE=verify-ca
# DATABASE_SSLROOTCERT=/secrets/server-ca.pem
# DATABASE_SSLCERT=/secrets/client-cert.pem
# DATABASE_SSLKEY=/secrets/client-key.pem

# GCP Memorystore Redis
# REDIS_HOST=10.0.0.3
# REDIS_PORT=6379
# REDIS_TLS_ENABLED=false

# =============================================================================
# Azure Examples (Comment out if not using Azure)
# =============================================================================

# Azure Database for PostgreSQL
# DATABASE_HOST=myserver.postgres.database.azure.com
# DATABASE_PORT=5432
# DATABASE_USER=testmesh@myserver  # Note: @servername suffix required
# DATABASE_PASSWORD=your-azure-password
# DATABASE_DBNAME=testmesh
# DATABASE_SSLMODE=require

# Azure Cache for Redis
# REDIS_HOST=mycache.redis.cache.windows.net
# REDIS_PORT=6380
# REDIS_PASSWORD=your-primary-key
# REDIS_TLS_ENABLED=true

# Azure Event Hubs (Kafka-compatible)
# KAFKA_ENABLED=true
# KAFKA_BROKERS=mynamespace.servicebus.windows.net:9093
# KAFKA_SASL_ENABLED=true
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=$ConnectionString
# KAFKA_SASL_PASSWORD=Endpoint=sb://mynamespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-key
# KAFKA_TLS_ENABLED=true

# =============================================================================
# Confluent Cloud Examples (Comment out if not using Confluent)
# =============================================================================

# Confluent Cloud Kafka
# KAFKA_ENABLED=true
# KAFKA_BROKERS=pkc-abc123.us-east-1.aws.confluent.cloud:9092
# KAFKA_SASL_ENABLED=true
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_USERNAME=your-api-key
# KAFKA_SASL_PASSWORD=your-api-secret
# KAFKA_TLS_ENABLED=true

# =============================================================================
# Monitoring & Observability (Optional)
# =============================================================================

# Prometheus metrics endpoint
METRICS_ENABLED=true
METRICS_PORT=9090

# Jaeger tracing
JAEGER_ENABLED=false
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# OpenTelemetry
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# =============================================================================
# Advanced Configuration (Optional)
# =============================================================================

# Maximum concurrent test executions
MAX_CONCURRENT_EXECUTIONS=10

# Test execution timeout (seconds)
EXECUTION_TIMEOUT=300

# Scheduler settings
SCHEDULER_ENABLED=true
SCHEDULER_POLL_INTERVAL=60s

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_SECOND=100

# File upload limits
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# WebSocket settings
WS_PORT=5017
WS_READ_BUFFER_SIZE=1024
WS_WRITE_BUFFER_SIZE=1024
