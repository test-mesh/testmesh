			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"pm.test('Status code is 201', function () {",
							"    pm.response.to.have.status(201);",
							"});",
							"",
							"pm.test('Response has correct structure', function () {",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData).to.have.property('id');",
							"    pm.expect(jsonData).to.have.property('owner_id');",
							"    pm.expect(jsonData).to.have.property('type');",
							"    pm.expect(jsonData).to.have.property('name');",
							"    pm.expect(jsonData).to.have.property('status');",
							"    pm.expect(jsonData).to.have.property('archived');",
							"    pm.expect(jsonData).to.have.property('created_date');",
							"    pm.expect(jsonData).to.have.property('updated_date');",
							"});",
							"",
							"pm.test('Project data matches request', function () {",
							"    const jsonData = pm.response.json();",
							"    pm.expect(jsonData.name).to.eql('Test Project');",
							"    pm.expect(jsonData.type).to.eql('organization');",
							"    pm.expect(jsonData.status).to.eql('active');",
							"    pm.expect(jsonData.archived).to.eql(false);",
							"});",
							"",
							"pm.test('ID is valid UUID', function () {",
							"    const jsonData = pm.response.json();",
							"    const uuidRegex = /^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i;",
							"    pm.expect(jsonData.id).to.match(uuidRegex);",
							"    ",
							"    // Store project ID for subsequent tests",
							"    pm.environment.set('projectId', jsonData.id);",
							"});",
							"",
							"pm.test('Response time is less than 1000ms', function () {",
							"    pm.expect(pm.response.responseTime).to.be.below(1000);",
							"});"
						],
