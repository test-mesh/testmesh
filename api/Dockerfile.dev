FROM golang:1.24-alpine

# Install build tools
RUN apk add --no-cache git

# Set working directory
WORKDIR /app

# Copy go mod files
COPY go.mod go.sum* ./

# Download dependencies
RUN go mod download

# Copy source code
COPY . .

# Build binary
RUN go build -o testmesh-api .

# Expose port
EXPOSE 5016

# Run binary
CMD ["./testmesh-api"]
